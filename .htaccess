# Redireciona todas as requisições não correspondentes a arquivos ou diretórios para index.php
RewriteEngine On
RewriteBase /

# Não aplicar rewrite se o arquivo ou diretório existir
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ /index.php [L,QSA]

# Evita listagem de diretórios
Options -Indexes
