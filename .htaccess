RewriteEngine On
Options -Indexes

# Impede acesso HTTP direto a código interno e dependências.
RewriteRule ^(?:app|config|includes|pages|routes|vendor)(?:/|$) - [F,L,NC]
RewriteRule ^router\.php$ - [F,L,NC]

# Protege arquivos de configuração e metadados do projeto.
<FilesMatch "^(?:\.env(?:\..*)?|composer\.(?:json|lock))$">
    Require all denied
</FilesMatch>

# Redireciona a raiz do site para /login
RewriteRule ^$ /login [R=302,L]

# Evita redirecionar arquivos e pastas existentes
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# Redireciona chamadas de API para api.php
RewriteRule ^api/(.*)$ api.php?path=$1 [QSA,L]

# Envia /login, /dashboard, /contas etc. para index.php (mapeamento de rotas)
# Legenda:
# - URLs do tipo `/rota` serão reescritas internamente para `index.php?page=rota`.
# - Para adicionar novas rotas, atualize `routes/web.php` com o par `rota => arquivo`.
RewriteRule ^([a-zA-Z0-9_-]+)/?$ index.php?page=$1 [QSA,L]
